# ============================================
# GPTRACKER - Configuração OpenRAG
# ============================================

# OpenAI API Key (obrigatório)
OPENAI_API_KEY=sk-sua-chave-openai-aqui

# ============================================
# OpenRAG Configuration
# ============================================

# Ativar OpenRAG (true/false)
USE_OPENRAG=true

# URLs dos serviços OpenRAG
OPENRAG_API_URL=http://localhost:7860
OPENSEARCH_URL=http://localhost:9200
DOCLING_URL=http://localhost:5001
REDIS_URL=redis://:Redis@123456@localhost:6379

# Nome do índice no OpenSearch
OPENRAG_INDEX_NAME=gptracker_knowledge

# API Key para OpenRAG (opcional, para autenticação)
OPENRAG_API_KEY=

# ============================================
# OpenSearch Configuration
# ============================================

# Senha do admin do OpenSearch
OPENSEARCH_PASSWORD=Admin@123456

# Configurações de memória (ajustar conforme necessário)
OPENSEARCH_JAVA_OPTS=-Xms2g -Xmx2g

# ============================================
# Langflow Configuration
# ============================================

# Credenciais do admin do Langflow
LANGFLOW_ADMIN_USER=admin
LANGFLOW_ADMIN_PASSWORD=Admin@123456

# Número de workers
LANGFLOW_WORKERS=4

# ============================================
# Redis Configuration
# ============================================

# Senha do Redis (para cache de embeddings)
REDIS_PASSWORD=Redis@123456

# ============================================
# JWT Configuration (mantido do sistema atual)
# ============================================

JWT_SECRET_KEY=sua-chave-jwt-secreta-aqui

# ============================================
# API Configuration
# ============================================

API_PORT=5000
FLASK_ENV=production

# ============================================
# Logging
# ============================================

LOG_LEVEL=INFO
LOG_FILE=logs/gptracker.log

# ============================================
# Features Flags
# ============================================

# Ativar auto-sync de planilhas
ENABLE_AUTO_SYNC=true

# Ativar cache de embeddings
ENABLE_EMBEDDING_CACHE=true

# Ativar reranking de resultados
ENABLE_RERANKING=true

# Ativar busca híbrida (vetorial + keyword)
ENABLE_HYBRID_SEARCH=true

# ============================================
# Performance Tuning
# ============================================

# Número máximo de resultados na busca
MAX_SEARCH_RESULTS=10

# Tamanho do chunk para documentos
CHUNK_SIZE=512

# Overlap entre chunks
CHUNK_OVERLAP=50

# Estratégia de chunking (semantic, fixed, auto)
CHUNK_STRATEGY=semantic

# ============================================
# Model Configuration
# ============================================

# Modelo de embeddings
EMBEDDING_MODEL=text-embedding-3-large

# Modelo de chat
CHAT_MODEL=gpt-4-turbo

# Temperatura para geração
CHAT_TEMPERATURE=0.7

# Máximo de tokens na resposta
MAX_RESPONSE_TOKENS=1000
