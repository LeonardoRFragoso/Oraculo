{
  "name": "GPTRACKER - Data Ingestion Pipeline",
  "description": "Pipeline completo de ingestão de documentos com chunking semântico e indexação no OpenSearch",
  "version": "1.0.0",
  "nodes": [
    {
      "id": "file_loader",
      "type": "FileLoader",
      "position": {"x": 100, "y": 100},
      "data": {
        "component_name": "File Loader",
        "description": "Carrega arquivos de múltiplos formatos",
        "config": {
          "file_types": ["pdf", "docx", "xlsx", "csv", "txt"],
          "max_file_size": "50MB",
          "encoding": "utf-8"
        }
      }
    },
    {
      "id": "docling_parser",
      "type": "DoclingParser",
      "position": {"x": 300, "y": 100},
      "data": {
        "component_name": "Docling Parser",
        "description": "Parser inteligente com OCR e chunking semântico",
        "config": {
          "chunk_strategy": "semantic",
          "chunk_size": 512,
          "chunk_overlap": 50,
          "enable_ocr": true,
          "extract_tables": true,
          "extract_images": false
        }
      }
    },
    {
      "id": "metadata_extractor",
      "type": "MetadataExtractor",
      "position": {"x": 500, "y": 100},
      "data": {
        "component_name": "Metadata Extractor",
        "description": "Extrai metadados estruturados dos documentos",
        "config": {
          "extract_fields": [
            "cliente",
            "qtd_container",
            "ano_mes",
            "porto",
            "tipo_carga"
          ],
          "date_formats": ["YYYY-MM-DD", "DD/MM/YYYY", "YYYYMM"],
          "numeric_fields": ["qtd_container", "teus", "volumes"]
        }
      }
    },
    {
      "id": "embedding_generator",
      "type": "OpenAIEmbeddings",
      "position": {"x": 700, "y": 100},
      "data": {
        "component_name": "Embedding Generator",
        "description": "Gera embeddings usando text-embedding-3-large",
        "config": {
          "model": "text-embedding-3-large",
          "dimensions": 3072,
          "batch_size": 100,
          "cache_enabled": true,
          "cache_backend": "redis"
        }
      }
    },
    {
      "id": "opensearch_indexer",
      "type": "OpenSearchIndexer",
      "position": {"x": 900, "y": 100},
      "data": {
        "component_name": "OpenSearch Indexer",
        "description": "Indexa documentos no OpenSearch",
        "config": {
          "index_name": "gptracker_knowledge",
          "host": "http://opensearch:9200",
          "batch_size": 100,
          "refresh": "wait_for",
          "mapping": {
            "properties": {
              "content": {"type": "text"},
              "embedding": {
                "type": "knn_vector",
                "dimension": 3072,
                "method": {
                  "name": "hnsw",
                  "space_type": "cosinesimil",
                  "engine": "nmslib"
                }
              },
              "metadata": {
                "properties": {
                  "cliente": {"type": "keyword"},
                  "qtd_container": {"type": "integer"},
                  "ano_mes": {"type": "keyword"},
                  "porto": {"type": "keyword"},
                  "source_file": {"type": "keyword"},
                  "ingestion_timestamp": {"type": "date"}
                }
              }
            }
          }
        }
      }
    }
  ],
  "edges": [
    {
      "id": "edge_1",
      "source": "file_loader",
      "target": "docling_parser",
      "sourceHandle": "output",
      "targetHandle": "input"
    },
    {
      "id": "edge_2",
      "source": "docling_parser",
      "target": "metadata_extractor",
      "sourceHandle": "output",
      "targetHandle": "input"
    },
    {
      "id": "edge_3",
      "source": "metadata_extractor",
      "target": "embedding_generator",
      "sourceHandle": "output",
      "targetHandle": "input"
    },
    {
      "id": "edge_4",
      "source": "embedding_generator",
      "target": "opensearch_indexer",
      "sourceHandle": "output",
      "targetHandle": "input"
    }
  ],
  "variables": {
    "OPENSEARCH_URL": "http://opensearch:9200",
    "OPENAI_API_KEY": "${OPENAI_API_KEY}",
    "REDIS_URL": "redis://redis:6379",
    "INDEX_NAME": "gptracker_knowledge"
  }
}
