# Configurações do GPTRACKER
# Copie este arquivo para .env e configure suas chaves

# OpenAI API Key (obrigatório)
OPENAI_API_KEY=sk-sua-chave-openai-aqui

# JWT Secret Key para autenticação
JWT_SECRET_KEY=sua-chave-jwt-muito-secreta-aqui

# Configurações da API REST (opcional)
API_PORT=5000
FLASK_ENV=development

# Configurações do Streamlit (opcional)
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=false

# Configurações de segurança (opcional)
ENCRYPTION_KEY_PATH=encryption.key
BACKUP_ENABLED=true
AUDIT_LOG_ENABLED=true
